            except Exception as e:
                if mode == MODE_SELFENCAP:
                    raise RuntimeError("Package was produced in self‑encap mode and requires the ephemeral private key used at encryption time.")
                else:
                    raise

            # Derive shared secret by decapsulation (OpenSSL 3.4+ semantics)
            shared_secret = kem_decapsulate_from_path(priv_path, kem_ct, self.logger.log)

            # Rebuild context hash and keys
            if ver == VERSION_V2:
                digest = hashes.Hash(hashes.SHA256())
                digest.update(MAGIC)
                digest.update(struct.pack('>HHH', VERSION_V2, ALG_ID_MLKEM768, mode))
                digest.update(pub_pem)
                digest.update(kem_ct)
                ctx_hash = digest.finalize()
                k_enc, k_mac = kdf_keys(shared_secret, salt, ctx_hash)
                header = parsed["header"]
                hmac_input = header + pub_pem + kem_ct + salt + nonce + tag + ct
                mac_check = hmac_sha256(k_mac, (hmac_input,))
                if mac_check != hmac_b:
                    raise RuntimeError("HMAC verification failed — package may be tampered.")
                plaintext = aesgcm_decrypt(k_enc, nonce, tag, ct, aad=ctx_hash)
            elif ver == VERSION_V1:
                # v1 compatibility — no salt, hkdf salt=None; AAD unused; HMAC was over pub||kem||nonce||tag||ct
                digest = hashes.Hash(hashes.SHA256())
                digest.update(pub_pem)
                digest.update(kem_ct)
                ctx_hash = digest.finalize()
                hkdf = HKDF(algorithm=hashes.SHA256(), length=64, salt=None, info=b"Kyber-AESGCM-v1|" + ctx_hash)
                okm = hkdf.derive(shared_secret)
                k_enc, k_mac = okm[:32], okm[32:]
                mac_check = hmac_sha256(k_mac, (pub_pem, kem_ct, nonce, tag, ct))
                if mac_check != hmac_b:
                    raise RuntimeError("HMAC verification failed (v1).")
                plaintext = aesgcm_decrypt(k_enc, nonce, tag, ct, aad=None)
            else:
                raise RuntimeError("Unsupported package version.")

            # Try to decode as UTF-8 text
            try:
                decrypted_text = plaintext.decode('utf-8')
                self.logger.log("Text decryption successful.")
            except UnicodeDecodeError:
                # If it's not valid UTF-8, show as hex
                decrypted_text = f"[Binary data - {len(plaintext)} bytes]\n\nHex dump:\n{plaintext.hex()}"
                self.logger.log("Decryption successful, but content appears to be binary data.")
            
            # Display in text output area
            self.text_output.config(state=tk.NORMAL)
            self.text_output.delete(1.0, tk.END)
            self.text_output.insert(1.0, decrypted_text)
            self.text_output.config(state=tk.DISABLED)
            
            messagebox.showinfo(APP_NAME, "Text decryption successful.")
            
        except Exception as e:
            self.logger.log(f"Error: {str(e)}")
            messagebox.showerror(APP_NAME, f"Failed: {e}")


# ----------------------------- Entry point -----------------------------

def main():
    root = tk.Tk()
    App(root)
    root.mainloop()


if __name__ == "__main__":
    main()
