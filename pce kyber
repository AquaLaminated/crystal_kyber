# ----------------------------- Utility / Security helpers -----------------------------

def _not_root_check() -> None:
    if os.name == "posix":
        try:
            if os.geteuid() == 0:
                raise PermissionError("Refusing to run as root; please run unprivileged.")
        except AttributeError:
            pass


def _secure_tempfile(suffix: str = "", initial_bytes: Optional[bytes] = None) -> str:
    fd, path = tempfile.mkstemp(prefix="pq_", suffix=suffix, dir=None, text=False)
    try:
        os.fchmod(fd, stat.S_IRUSR | stat.S_IWUSR)  # 0o600
        if initial_bytes:
            os.write(fd, initial_bytes)
    finally:
        os.close(fd)
    return path


def _run(cmd: list, *, input_bytes: Optional[bytes] = None, timeout: int = 25) -> Tuple[int, bytes, bytes]:
    # Pass through all environment variables, especially the OQS provider ones
    env = dict(os.environ)
    env.update({"LC_ALL": "C", "LANG": "C"})
    try:
        p = subprocess.run(
            cmd,
            input=input_bytes,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
            timeout=timeout,
            start_new_session=True,
            close_fds=True,
            env=env,
        )
        return p.returncode, p.stdout, p.stderr
    except subprocess.TimeoutExpired as e:
        return 124, e.stdout or b"", e.stderr or b"timeout"


# ----------------------------- OpenSSL capability checks -----------------------------

def check_openssl_support(logfn) -> Tuple[str, bool, Optional[str]]:
    rc, out, err = _run([OPENSSL_BIN, "version", "-v"], timeout=10)
    if rc != 0:
        raise RuntimeError(f"OpenSSL not found or failed to run: {err.decode(errors='ignore')}")
    ver = out.decode().strip()
    logfn(f"OpenSSL: {ver}")

    rc, out, _ = _run([OPENSSL_BIN, "list", "-kem-algorithms", "-provider", OQS_PROVIDER_NAME, "-provider", "default"], timeout=10)
    alg_name = None
    if rc == 0:
        text = out.decode(errors="ignore")
        for name in KEM_ALGOS:
            if name.lower() in text.lower():
                alg_name = name
                break
    return ver, alg_name is not None, alg_name


# ----------------------------- KEM and key handling -----------------------------

def generate_mlkem_keypair_pem(alg_name: str, logfn) -> Tuple[bytes, bytes]:
    """Generate ML-KEM keypair using liboqs (preferred) or OpenSSL fallback"""
    
    # First try liboqs (Python OQS bindings) - this bypasses OpenSSL encoder issues
    try:
        logfn("Trying liboqs (Python OQS bindings) for key generation...")
        import oqs  # type: ignore
        logfn("liboqs module imported successfully")
        
        # Map algorithm names to liboqs format
        liboqs_algo_map = {
            "mlkem768": "ML-KEM-768",
            "ML-KEM-768": "ML-KEM-768", 
            "MLKEM-768": "ML-KEM-768",
            "kyber768": "ML-KEM-768",
            "Kyber768": "ML-KEM-768",
            "ml-kem-768": "ML-KEM-768"
        }
        
        liboqs_algo = liboqs_algo_map.get(alg_name, "ML-KEM-768")
        logfn(f"Using liboqs algorithm: {liboqs_algo}")
        
        # Create KEM object and generate keypair
        logfn("Creating KEM object...")
        kem = oqs.KeyEncapsulation(liboqs_algo)
        logfn("Generating keypair...")
        public_key = kem.generate_keypair()
        logfn("Exporting private key...")
        private_key = kem.export_secret_key()
        logfn("Key generation completed successfully")
        
        # Store the KEM object globally for later use in decapsulation
        # This is a simple approach - in production you'd want better key management
        import threading
        if not hasattr(threading.current_thread(), 'liboqs_kem_objects'):
            threading.current_thread().liboqs_kem_objects = {}
        
        # Store the KEM object with the private key for later decapsulation
        key_id = private_key.hex()[:16]  # Use first 16 chars as key ID
        threading.current_thread().liboqs_kem_objects[key_id] = kem
        
        # Also store in a global dictionary as backup
        if not hasattr(generate_mlkem_keypair_pem, '_global_kem_objects'):
            generate_mlkem_keypair_pem._global_kem_objects = {}
        generate_mlkem_keypair_pem._global_kem_objects[key_id] = kem
        
        # Convert to PEM format with key ID for later retrieval
        priv_pem = f"""-----BEGIN LIBOQS PRIVATE KEY-----
Key-ID: {key_id}
Algorithm: {liboqs_algo}
Private-Key: {private_key.hex()}
-----END LIBOQS PRIVATE KEY-----""".encode()
        
        pub_pem = f"""-----BEGIN LIBOQS PUBLIC KEY-----
Key-ID: {key_id}
Algorithm: {liboqs_algo}
Public-Key: {public_key.hex()}
-----END LIBOQS PUBLIC KEY-----""".encode()
        
        logfn(f"✅ Generated ML-KEM keypair using liboqs (Python OQS bindings)")
        return priv_pem, pub_pem
        
    except ImportError:
        logfn("liboqs not available, trying OpenSSL approaches...")
    except Exception as e:
        logfn(f"liboqs key generation failed: {e}, trying OpenSSL approaches...")
    
    # Fallback to OpenSSL approaches
    approaches = [
        # Approach 1: Direct generation
        [OPENSSL_BIN, "genpkey", "-algorithm", alg_name, "-outform", "PEM"],
        # Approach 2: With explicit providers
        [OPENSSL_BIN, "genpkey", "-provider", "default", "-algorithm", alg_name, "-outform", "PEM"],
        # Approach 3: Using system OQS provider
        [OPENSSL_BIN, "genpkey", "-provider", "oqs", "-algorithm", alg_name, "-outform", "PEM"],
    ]
    
    for i, cmd in enumerate(approaches, 1):
        logfn(f"Trying OpenSSL key generation approach {i}...")
        rc, out, err = _run(cmd, timeout=20)
        if rc == 0 and out:
            priv_pem = out
            # Try to extract public key
            cmd2 = [OPENSSL_BIN, "pkey", "-pubout"]
            rc2, out2, err2 = _run(cmd2, input_bytes=priv_pem, timeout=10)
            if rc2 == 0 and out2:
                pub_pem = out2
                logfn(f"Generated fresh ML‑KEM keypair using OpenSSL approach {i} (private key never written to disk).")
                return priv_pem, pub_pem
            else:
                logfn(f"OpenSSL approach {i} generated private key but failed to extract public key")
        else:
            logfn(f"OpenSSL approach {i} failed: {err.decode(errors='ignore')[:100]}...")
    
    # If all approaches fail, provide helpful error
    raise RuntimeError(
        "Key generation failed with all approaches (liboqs and OpenSSL). "
        "Please use the 'Recipient public key' field to provide an existing ML-KEM public key, "
        "or use the File Encryption section instead."
    )


def pub_from_private_path(priv_path: Path) -> bytes:
    rc, out, err = _run([OPENSSL_BIN, "pkey", "-pubout", "-in", str(priv_path)], timeout=10)
    if rc != 0:
        raise RuntimeError(f"Failed to derive public key from private: {err.decode(errors='ignore')}")
    return out


def kem_encapsulate(pub_pem: bytes, logfn) -> Tuple[bytes, bytes]:
    # First try liboqs (Python OQS bindings) - this bypasses OpenSSL encoder issues
    try:
        import oqs  # type: ignore
        logfn("Trying liboqs (Python OQS bindings) for encapsulation...")
        
        # Check if this is a liboqs key format
        if b'-----BEGIN LIBOQS PUBLIC KEY-----' in pub_pem:
            # Parse liboqs key format
            pub_key_hex = None
            algorithm = None
            
            for line in pub_pem.decode().split('\n'):
                line = line.strip()
                if line.startswith('Public-Key:'):
                    pub_key_hex = line.split(':', 1)[1].strip()
                elif line.startswith('Algorithm:'):
                    algorithm = line.split(':', 1)[1].strip()
            
            if pub_key_hex and algorithm:
                # Convert hex to bytes
                pub_key_bytes = bytes.fromhex(pub_key_hex)
                
                # Create KEM object and encapsulate
                kem = oqs.KeyEncapsulation(algorithm)
                kem_ct, shared_secret = kem.encap_secret(pub_key_bytes)
                
                logfn("✅ Encapsulated shared secret using liboqs (Python OQS bindings)")
                return kem_ct, shared_secret
        else:
            # Try to parse as standard PEM format
            pub_key_hex = None
            for line in pub_pem.decode().split('\n'):
                if line.strip() and not line.startswith('-----'):
                    pub_key_hex = line.strip()
                    break
            
            if pub_key_hex:
                # Convert hex to bytes
                pub_key_bytes = bytes.fromhex(pub_key_hex)
                
                # Create KEM object and encapsulate
                kem = oqs.KeyEncapsulation("ML-KEM-768")
                kem_ct, shared_secret = kem.encap_secret(pub_key_bytes)
                
                logfn("✅ Encapsulated shared secret using liboqs (Python OQS bindings)")
                return kem_ct, shared_secret
        
    except ImportError:
        logfn("liboqs not available, trying OpenSSL approach...")
    except Exception as e:
        logfn(f"liboqs encapsulation failed: {e}, trying OpenSSL approach...")
    
    # Fallback to OpenSSL approach
    secret_path = _secure_tempfile(suffix=".bin")
    pub_path = _secure_tempfile(suffix=".pem", initial_bytes=pub_pem)
    try:
        cmd = [
            OPENSSL_BIN, "pkeyutl", "-encap", "-pubin",
            "-inkey", pub_path,
            "-secret", secret_path,
        ]
        rc, out, err = _run(cmd, timeout=25)
        if rc != 0:
            raise RuntimeError(f"pkeyutl -encap failed: {err.decode(errors='ignore')}")
        kem_ct = out  # ciphertext on stdout if -out not specified
        with open(secret_path, "rb") as f:
            shared_secret = f.read()
        if not kem_ct or not shared_secret:
            raise RuntimeError("Encapsulation produced empty outputs.")
        logfn("Encapsulated shared secret with ML‑KEM using OpenSSL.")
        return kem_ct, shared_secret
    finally:
        for p in (secret_path, pub_path):
            try: os.unlink(p)
            except Exception: pass


def kem_decapsulate_from_path(priv_path: Path, kem_ct: bytes, logfn) -> bytes:
    """Decapsulate using recipient private key file with liboqs (preferred) or OpenSSL fallback"""
    
    # First try liboqs (Python OQS bindings) - this bypasses OpenSSL encoder issues
    try:
        import oqs  # type: ignore
        import threading
        logfn("Trying liboqs (Python OQS bindings) for decapsulation...")
        
        # Read private key from file
        with open(priv_path, 'rb') as f:
            priv_pem = f.read()
        
        # Check if this is a liboqs key format
        if b'-----BEGIN LIBOQS PRIVATE KEY-----' in priv_pem:
            # Parse liboqs key format
            key_id = None
            private_key_hex = None
            algorithm = None
            
            for line in priv_pem.decode().split('\n'):
                line = line.strip()
                if line.startswith('Key-ID:'):
                    key_id = line.split(':', 1)[1].strip()
                elif line.startswith('Algorithm:'):
                    algorithm = line.split(':', 1)[1].strip()
                elif line.startswith('Private-Key:'):
                    private_key_hex = line.split(':', 1)[1].strip()
            
            if key_id and private_key_hex and algorithm:
                # Try to find the stored KEM object in thread-local storage
                if hasattr(threading.current_thread(), 'liboqs_kem_objects'):
                    kem_objects = threading.current_thread().liboqs_kem_objects
                    if key_id in kem_objects:
                        kem = kem_objects[key_id]
                        shared_secret = kem.decap_secret(kem_ct)
                        logfn("✅ Decapsulated shared secret using stored liboqs KEM object")
                        return shared_secret
                
                # Try to find the stored KEM object in global storage
                if hasattr(generate_mlkem_keypair_pem, '_global_kem_objects'):
                    global_kem_objects = generate_mlkem_keypair_pem._global_kem_objects
                    if key_id in global_kem_objects:
                        kem = global_kem_objects[key_id]
                        shared_secret = kem.decap_secret(kem_ct)
                        logfn("✅ Decapsulated shared secret using global liboqs KEM object")
                        return shared_secret
                
                # If no stored KEM object, create a new one (this won't work for decapsulation)
                logfn("No stored KEM object found, liboqs decapsulation not possible")
                raise NotImplementedError("liboqs private key import not supported")
        
        # Not a liboqs key format, try OpenSSL fallback
        logfn("Not a liboqs key format, trying OpenSSL approach...")
        raise NotImplementedError("Not a liboqs key")
        
    except ImportError:
        logfn("liboqs not available, trying OpenSSL approach...")
    except Exception as e:
        logfn(f"liboqs decapsulation failed: {e}, trying OpenSSL approach...")
    
    # Fallback to OpenSSL approach
    kem_in = _secure_tempfile(suffix=".bin", initial_bytes=kem_ct)
    secret_out = _secure_tempfile(suffix=".bin")
    try:
        # Try different OpenSSL approaches for decapsulation
        approaches = [
            # Try with -derive (for key derivation)
            [OPENSSL_BIN, "pkeyutl", "-derive", "-inkey", str(priv_path), "-in", kem_in, "-out", secret_out],
            # Try with -decrypt
            [OPENSSL_BIN, "pkeyutl", "-decrypt", "-inkey", str(priv_path), "-in", kem_in, "-out", secret_out],
        ]
        
        for i, cmd in enumerate(approaches, 1):
            logfn(f"Trying OpenSSL decapsulation approach {i}...")
            rc, _, err = _run(cmd, timeout=25)
            if rc == 0:
                with open(secret_out, "rb") as f:
                    shared = f.read()
                if shared:
                    logfn(f"Decapsulated shared secret with ML‑KEM using OpenSSL approach {i}.")
                    return shared
        
        # If all approaches fail
        raise RuntimeError(f"All OpenSSL decapsulation approaches failed: {err.decode(errors='ignore')}")
        
    finally:
        for p in (kem_in, secret_out):
            try: os.unlink(p)
            except Exception: pass


# ----------------------------- Crypto (HKDF, AES‑GCM, HMAC) -----------------------------


def kdf_keys(shared_secret: bytes, salt: bytes, context_hash: bytes) -> Tuple[bytes, bytes]:
    hkdf = HKDF(algorithm=hashes.SHA256(), length=64, salt=salt, info=b"Kyber-AESGCM-v2|" + context_hash)
    okm = hkdf.derive(shared_secret)
    return okm[:32], okm[32:]


def aesgcm_encrypt(key: bytes, nonce: bytes, plaintext: bytes, aad: Optional[bytes]) -> Tuple[bytes, bytes]:
    aead = AESGCM(key)
    ct = aead.encrypt(nonce, plaintext, associated_data=aad)
    return ct[:-GCM_TAG_LEN], ct[-GCM_TAG_LEN:]


def aesgcm_decrypt(key: bytes, nonce: bytes, tag: bytes, ciphertext: bytes, aad: Optional[bytes]) -> bytes:
    aead = AESGCM(key)
    return aead.decrypt(nonce, ciphertext + tag, associated_data=aad)


def hmac_sha256(key: bytes, parts: Tuple[bytes, ...]) -> bytes:
    hm = hmac.new(key, digestmod=hashes.SHA256().name)
    for p in parts: hm.update(p)
    return hm.digest()


# ----------------------------- Packager -----------------------------

def build_header_v2(alg_id: int, mode: int, pub_pem: bytes, kem_ct: bytes, salt: bytes, nonce: bytes, tag: bytes, ciphertext: bytes) -> bytes:
    return struct.pack(
        ">4sHHHIIHHHQH",
        MAGIC,
        VERSION_V2,
        alg_id,
        mode,
        len(pub_pem),
        len(kem_ct),
        len(salt),
        len(nonce),
        len(tag),
        len(ciphertext),
        HMAC_LEN,
    )


def parse_package(data: bytes) -> dict:
    # Try v2 first
    if len(data) >= 4+2+2:
        magic = data[:4]
        if magic != MAGIC:
            raise ValueError("Not a PQPK package (bad magic)")
        (magic, ver) = struct.unpack(">4sH", data[:6])
        if ver == VERSION_V2:
            fmt = ">4sHHHIIHHHQH"
            hdr_len = struct.calcsize(fmt)
            if len(data) < hdr_len:
                raise ValueError("Truncated header")
            (magic, ver, alg, mode, pub_len, kem_len, salt_len, nonce_len, tag_len, ct_len, hmac_len) = struct.unpack(fmt, data[:hdr_len])
            off = hdr_len
            pub = data[off:off+pub_len]; off += pub_len
            kem = data[off:off+kem_len]; off += kem_len
            salt = data[off:off+salt_len]; off += salt_len
            nonce = data[off:off+nonce_len]; off += nonce_len
            tag = data[off:off+tag_len]; off += tag_len
            ct = data[off:off+ct_len]; off += ct_len
            hmac_b = data[off:off+hmac_len]; off += hmac_len
            if off != len(data):
                raise ValueError("Extra bytes after HMAC")
            return {
                "version": ver, "alg": alg, "mode": mode, "header": data[:hdr_len],
                "pub": pub, "kem": kem, "salt": salt, "nonce": nonce, "tag": tag, "ct": ct, "hmac": hmac_b,
            }
        elif ver == VERSION_V1:
            # v1 layout from previous release
            fmt = ">4sHHIIIIQI"
            hdr_len = struct.calcsize(fmt)
            (magic, ver, alg, pub_len, kem_len, nonce_len, tag_len, ct_len, hmac_len) = struct.unpack(fmt, data[:hdr_len])
            off = hdr_len
            pub = data[off:off+pub_len]; off += pub_len
            kem = data[off:off+kem_len]; off += kem_len
            nonce = data[off:off+nonce_len]; off += nonce_len
            tag = data[off:off+tag_len]; off += tag_len
            ct = data[off:off+ct_len]; off += ct_len
            hmac_b = data[off:off+hmac_len]; off += hmac_len
            if off != len(data): raise ValueError("Extra bytes after HMAC (v1)")
            return {
                "version": ver, "alg": alg, "mode": MODE_SELFENCAP, "header": data[:hdr_len],
                "pub": pub, "kem": kem, "salt": b"", "nonce": nonce, "tag": tag, "ct": ct, "hmac": hmac_b,
            }
        else:
            raise ValueError(f"Unsupported package version: {ver}")
    raise ValueError("Truncated or invalid package")


# ----------------------------- Logging (GUI + file) -----------------------------
class SafeLogger:
    REDACT = "[redacted]"
    def __init__(self, text_widget: scrolledtext.ScrolledText):
        self.text = text_widget
        self._log_file_path: Optional[Path] = None
    def set_log_path(self, path: Path):
        self._log_file_path = path
    def _write(self, line: str):
        ts = time.strftime("%Y-%m-%d %H:%M:%S")
        msg = f"[{ts}] {line}\n"
        self.text.insert(tk.END, msg)
        self.text.see(tk.END)
        if self._log_file_path:
            with open(self._log_file_path, "a", encoding="utf-8") as f:
                f.write(msg)
    def log(self, line: str):
        if any(s in line.lower() for s in ["private key", "secret", "shared", "seed", "nonce:"]):
            line = self.REDACT
        self._write(line)


