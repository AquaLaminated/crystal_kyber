    def encrypt(self):
        in_path = Path(self.in_path.get()).expanduser()
        out_path = Path(self.out_path.get()).expanduser()
        rec_pub_path = Path(self.recipient_pub_path.get()).expanduser() if self.recipient_pub_path.get() else None
        if not in_path.is_file():
            messagebox.showerror(APP_NAME, "Select a valid input file.")
            return
        if not out_path.parent.exists():
            messagebox.showerror(APP_NAME, "Select a valid output location.")
            return
        log_path = out_path.with_suffix(out_path.suffix + ".log")
        self.logger.set_log_path(log_path)
        self.logger.log(f"Input: {str(in_path)}")
        self.logger.log(f"Output: {str(out_path)}")
        
        plaintext = None
        try:
            _, has, alg = check_openssl_support(self.logger.log)
            if not has:
                raise RuntimeError("ML-KEM/Kyber not available in this OpenSSL build.")
            alg_name = alg or KEM_ALGOS[0]
            self.logger.log(f"Using KEM algorithm: {alg_name}")

            # Use recipient-provided key or generate ephemeral key
            if rec_pub_path and rec_pub_path.exists():
                pub_pem = Path(rec_pub_path).read_bytes()
                mode = MODE_RECIPIENT
                self.logger.log("Recipient mode: encapsulating to provided public key.")
                # Encapsulate to recipient's public key
                kem_ct, shared_secret = kem_encapsulate(pub_pem, self.logger.log)
            else:
                # Generate ephemeral keypair using liboqs or OpenSSL fallback
                try:
                    priv_pem, pub_pem = generate_mlkem_keypair_pem(alg_name, self.logger.log)
                    mode = MODE_SELFENCAP
                    self.logger.log("Self-encap mode: ephemeral key used; package non-recoverable later.")
                    # Encapsulate to our own public key
                    kem_ct, shared_secret = kem_encapsulate(pub_pem, self.logger.log)
                except RuntimeError as e:
                    # Show a helpful error message for any key generation failure
                    messagebox.showerror(
                        APP_NAME, 
                        f"Key generation failed: {e}\n\n"
                        "Please provide a recipient public key file in the 'Recipient public key' field above, "
                        "or use the Text Encryption section instead.\n\n"
                        "The recipient public key should be a ML-KEM public key in PEM format."
                    )
                    return

            # Build context hash for key derivation and AAD
            digest = hashes.Hash(hashes.SHA256())
            digest.update(MAGIC)
            digest.update(struct.pack('>HHH', VERSION_V2, ALG_ID_MLKEM768, mode))
            digest.update(pub_pem)
            digest.update(kem_ct)
            ctx_hash = digest.finalize()

            # Derive encryption and MAC keys
            salt = os.urandom(DEFAULT_SALT_LEN)
            k_enc, k_mac = kdf_keys(shared_secret, salt, ctx_hash)
            
            # Encrypt the file content
            nonce = os.urandom(NONCE_LEN)
            plaintext = in_path.read_bytes()
            ciphertext, tag = aesgcm_encrypt(k_enc, nonce, plaintext, aad=ctx_hash)

            # Build package
            header = build_header_v2(ALG_ID_MLKEM768, mode, pub_pem, kem_ct, salt, nonce, tag, ciphertext)
            hmac_input = header + pub_pem + kem_ct + salt + nonce + tag + ciphertext
            mac = hmac_sha256(k_mac, (hmac_input,))
            pkg = header + pub_pem + kem_ct + salt + nonce + tag + ciphertext + mac

            # Write package to file
            with open(out_path, "wb") as f:
                f.write(pkg)

            # Write metadata to log
            meta = {
                "app": APP_NAME,
                "openssl": subprocess.run([OPENSSL_BIN, "version", "-v"], capture_output=True, text=True).stdout.strip(),
                "provider": OQS_PROVIDER_NAME,
                "mode": "recipient" if mode == MODE_RECIPIENT else "self-encap",
                "nonce_len": NONCE_LEN,
                "tag_len": GCM_TAG_LEN,
                "salt_len": DEFAULT_SALT_LEN,
                "input_size": len(plaintext),
                "ciphertext_size": len(ciphertext),
                "kem_ct_size": len(kem_ct),
                "pub_pem_len": len(pub_pem),
                "package_size": len(pkg),
                "username": getpass.getuser(),
                "timestamp": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
                "content_type": "file"
            }
            with open(log_path, "a", encoding="utf-8") as lf:
                lf.write(json.dumps(meta, indent=2) + "\n")

            self.logger.log(f"Saved package: {str(out_path)}")
            self.logger.log(f"Saved log: {str(log_path)}")
            messagebox.showinfo(APP_NAME, "Encryption successful.")
            
        except Exception as e:
            self.logger.log(f"Error: {str(e)}")
            messagebox.showerror(APP_NAME, f"Failed: {e}")
                  
        finally:
            # Best‑effort zeroization of plaintext
            try:
                if plaintext is not None and isinstance(plaintext, (bytes, bytearray)):
                    ba = bytearray(plaintext)
                    for i in range(len(ba)): 
                        ba[i] = 0
            except Exception:
                pass

