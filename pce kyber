            mode = parsed.get("mode", MODE_SELFENCAP)
            self.logger.log(f"Package version: {ver}; mode: {('recipient' if mode==MODE_RECIPIENT else 'self-encap')}.")
            # Structural details only; integrity needs decrypt (HMAC)
            self.logger.log(f"pub_len={len(parsed['pub'])}, kem_len={len(parsed['kem'])}, ct_len={len(parsed['ct'])}")
            messagebox.showinfo(APP_NAME, "Package parsed successfully. Full integrity requires decrypt step (HMAC check).")
        except Exception as e:
            self.logger.log(f"Error: {str(e)}")
            messagebox.showerror(APP_NAME, f"Failed: {e}")

    # ---------- Core: Decrypt ----------
    def decrypt(self):
        pkg_path = Path(self.pkg_path.get()).expanduser()
        out_path = Path(self.dec_out_path.get()).expanduser()
        priv_path = Path(self.recipient_priv_path.get()).expanduser()
        if not pkg_path.is_file():
            messagebox.showerror(APP_NAME, "Select a valid package.")
            return
        if not out_path.parent.exists():
            messagebox.showerror(APP_NAME, "Select a valid output path.")
            return
        if not priv_path.is_file():
            messagebox.showerror(APP_NAME, "Select a valid recipient private key (PEM).")
            return
        log_path = out_path.with_suffix(out_path.suffix + ".log")
        self.logger.set_log_path(log_path)
        self.logger.log(f"Package: {str(pkg_path)}")
        self.logger.log(f"Output: {str(out_path)}")
        try:
            data = pkg_path.read_bytes()
            parsed = parse_package(data)
            ver = parsed["version"]
            mode = parsed.get("mode", MODE_SELFENCAP)
            pub_pem = parsed["pub"]
            kem_ct = parsed["kem"]
            salt = parsed["salt"] if ver==VERSION_V2 else b""
            nonce = parsed["nonce"]
            tag = parsed["tag"]
            ct = parsed["ct"]
            hmac_b = parsed["hmac"]

            # Verify provided private key matches embedded public key
            try:
                pub_from_priv = pub_from_private_path(priv_path)
                if pub_from_priv.strip() != pub_pem.strip():
                    raise RuntimeError("Provided private key does not match package public key.")
            except Exception as e:
                if mode == MODE_SELFENCAP:
                    raise RuntimeError("Package was produced in self‑encap mode and requires the ephemeral private key used at encryption time.")
                else:
                    raise

            # Derive shared secret by decapsulation (OpenSSL 3.4+ semantics)
            shared_secret = kem_decapsulate_from_path(priv_path, kem_ct, self.logger.log)

            # Rebuild context hash and keys
            if ver == VERSION_V2:
                digest = hashes.Hash(hashes.SHA256()); digest.update(MAGIC); digest.update(struct.pack('>HHH', VERSION_V2, ALG_ID_MLKEM768, mode)); digest.update(pub_pem); digest.update(kem_ct)
                ctx_hash = digest.finalize()
                k_enc, k_mac = kdf_keys(shared_secret, salt, ctx_hash)
                header = parsed["header"]
                hmac_input = header + pub_pem + kem_ct + salt + nonce + tag + ct
                mac_check = hmac_sha256(k_mac, (hmac_input,))
                if mac_check != hmac_b:
                    raise RuntimeError("HMAC verification failed — package may be tampered.")
                plaintext = aesgcm_decrypt(k_enc, nonce, tag, ct, aad=ctx_hash)
            elif ver == VERSION_V1:
                # v1 compatibility — no salt, hkdf salt=None; AAD unused; HMAC was over pub||kem||nonce||tag||ct
                digest = hashes.Hash(hashes.SHA256()); digest.update(pub_pem); digest.update(kem_ct); ctx_hash = digest.finalize()
                hkdf = HKDF(algorithm=hashes.SHA256(), length=64, salt=None, info=b"Kyber-AESGCM-v1|" + ctx_hash)
                okm = hkdf.derive(shared_secret); k_enc, k_mac = okm[:32], okm[32:]
                mac_check = hmac_sha256(k_mac, (pub_pem, kem_ct, nonce, tag, ct))
                if mac_check != hmac_b:
                    raise RuntimeError("HMAC verification failed (v1).")
                plaintext = aesgcm_decrypt(k_enc, nonce, tag, ct, aad=None)
            else:
                raise RuntimeError("Unsupported package version.")

            with open(out_path, "wb") as f: f.write(plaintext)
            self.logger.log("Decryption successful.")
            messagebox.showinfo(APP_NAME, "Decryption successful.")
        except Exception as e:
            self.logger.log(f"Error: {str(e)}")
            messagebox.showerror(APP_NAME, f"Failed: {e}")

